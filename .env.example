# Optional real provider settings.
# Leave LAUNCHLENS_PROVIDER_LIVE_ENABLED blank to use the built-in mock/demo
# workspace provider even when local provider keys exist.
LAUNCHLENS_PROVIDER_LIVE_ENABLED=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional MiniMax Token Plan provider settings.
# Keep real values in .env.local or another untracked local env file.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Optional live provider use for the evidence-grounded decision copilot.
# Leave blank to keep decision briefs deterministic in demo mode.
DECISION_COPILOT_LIVE_ENABLED=

# Optional durable cloud workspace history.
# Vercel Marketplace Neon injects DATABASE_URL automatically.
DATABASE_URL=
# Optional elevated credential used only by `npm run db:migrate`.
DATABASE_MIGRATION_URL=

# Optional commercial preview envelope when no persisted subscription exists.
LAUNCHLENS_COMMERCIAL_PLAN=team

# Optional Stripe subscription billing.
# Checkout remains disabled unless all four Stripe values are configured.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=

# Canonical HTTPS origin used for Checkout and Billing Portal return URLs.
# Local development may fall back to http://localhost.
NEXT_PUBLIC_APP_URL=
